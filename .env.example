# HTTP Server
HOST=0.0.0.0
PORT=4000

# YAML Config Directory
CONFIG_DIR=config

# InfluxDB 3
INFLUXDB_URL=http://localhost:8181
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_DATABASE=tesla

# Tesla Owner API
TESLA_API_CLIENT_ID=ownerapi
TESLA_AUTH_URL=https://auth.tesla.com
TESLA_API_URL=https://owner-api.teslamotors.com

# Token Encryption (32-byte hex for AES-256-GCM)
DATA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Logging
RUST_LOG=info
LOG_FORMAT=text
# LOG_FILE=data/teslamate.log  # optional file log (appended alongside stdout)

# MQTT (optional)
# MQTT_HOST=localhost
# MQTT_PORT=1883

# Vehicle Polling (online/parked interval; driving uses 2.5s automatically)
POLL_INTERVAL_SECONDS=60

# Streaming API
STREAMING_ENABLED=false

# Grafana (optional)
# GRAFANA_URL=http://localhost:3000
