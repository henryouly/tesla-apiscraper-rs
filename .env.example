# HTTP Server
HOST=0.0.0.0
PORT=4000

# YAML Config Directory
CONFIG_DIR=config

# InfluxDB 3
INFLUXDB_URL=http://localhost:8181
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_DATABASE=tesla

# Tesla API
TESLA_API_CLIENT_ID=your-client-id
TESLA_API_CLIENT_SECRET=your-client-secret
TESLA_AUTH_URL=https://auth.tesla.com
TESLA_API_URL=https://fleet-api.prd.na.vn.cloud.tesla.com

# Token Encryption (32-byte hex for AES-256-GCM)
DATA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Logging
RUST_LOG=info
LOG_FORMAT=text

# MQTT (optional)
# MQTT_HOST=localhost
# MQTT_PORT=1883

# Vehicle Polling
POLL_INTERVAL_SECONDS=30

# Streaming API
STREAMING_ENABLED=false

# Grafana (optional)
# GRAFANA_URL=http://localhost:3000
